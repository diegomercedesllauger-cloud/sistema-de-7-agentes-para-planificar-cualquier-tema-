class Agente4_PreguntasSocraticas:
    """Genera preguntas que fuerzan pensamiento activo (Generation Effect)."""
    
    def __init__(self):
        self.preguntas_por_tema = {
            "RSA": {
                "nivel_1": [
                    "¿Cuál es la fórmula básica de RSA?",
                    "¿Qué significan n, e, y d en RSA?"
                ],
                "nivel_2": [
                    "¿Por qué es fácil multiplicar pero difícil factorizar?",
                    "Si conoces n=p×q, ¿por qué no encuentras p y q fácilmente?"
                ],
                "nivel_3": [
                    "Demuestra por qué c^d ≡ m (mod n) funciona",
                    "¿Qué pasa si alguien factoriza rápido?"
                ]
            }
        }
    
    def generar_preguntas(self, tema):
        if tema in self.preguntas_por_tema:
            preguntas = self.preguntas_por_tema[tema]
        else:
            preguntas = self._generar_dinamicas(tema)
        
        return {
            "tema": tema,
            "preguntas_nivel_1": preguntas.get("nivel_1", []),
            "preguntas_nivel_2": preguntas.get("nivel_2", []),
            "preguntas_nivel_3": preguntas.get("nivel_3", []),
        }
    
    def _generar_dinamicas(self, tema):
        return {
            "nivel_1": [f"¿Qué es {tema}?"],
            "nivel_2": [f"¿Por qué es importante {tema}?"],
            "nivel_3": [f"¿Cuáles son los límites de {tema}?"]
        }


