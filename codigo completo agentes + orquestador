# AGENTE 1: ANALIZADOR DE COMPLEJIDAD COGNITIVA
# ============================================================

class Agente1_Analizador:
    """Analiza complejidad del tema y detecta conceptos previos necesarios."""
    
    def __init__(self):
        self.temas_conocidos = {
            "Ciberseguridad": {"tipo": "técnico", "complejidad_base": 7},
            "Matemáticas": {"tipo": "abstracto", "complejidad_base": 6},
            "Física": {"tipo": "conceptual+matemática", "complejidad_base": 7},
            "Química": {"tipo": "visual+cuantitativa", "complejidad_base": 6},
            "Historia": {"tipo": "narrativo", "complejidad_base": 4},
        }
        
        self.prerequisitos = {
            "RSA": ["Números primos", "Factorización", "Aritmética modular"],
            "Derivadas": ["Funciones", "Límites", "Álgebra"],
            "Equilibrio Químico": ["Reacciones químicas", "Estequiometría"],
        }
    
    def analizar(self, tema, conceptos_que_sabes):
        tipo_tema = self._detectar_tipo(tema)
        complejidad_base = self.temas_conocidos.get(
            tipo_tema, {"complejidad_base": 5})["complejidad_base"]
        
        previos_requeridos = self.prerequisitos.get(tema, [])
        previos_faltantes = [c for c in previos_requeridos if c not in conceptos_que_sabes]
        
        complejidad_ajustada = complejidad_base + len(previos_faltantes) * 0.5
        complejidad_ajustada = min(10, complejidad_ajustada)
        
        tiempo_estimado = self._estimar_tiempo(complejidad_ajustada)
        metodo = self._recomendar_metodo(tipo_tema, complejidad_ajustada)
        
        return {
            "tema": tema,
            "tipo": tipo_tema,
            "complejidad": round(complejidad_ajustada, 1),
            "conceptos_previos_necesarios": previos_requeridos,
            "conceptos_faltantes": previos_faltantes,
            "tiempo_estimado_horas": tiempo_estimado,
            "metodo_recomendado": metodo,
            "prioridad_estudio": "CRÍTICA" if complejidad_ajustada > 7 else "ALTA" if complejidad_ajustada > 5 else "MEDIA"
        }
    
    def _detectar_tipo(self, tema):
        tema_lower = tema.lower()
        if any(word in tema_lower for word in ["crypto", "rsa", "ataque", "seguridad"]):
            return "Ciberseguridad"
        elif any(word in tema_lower for word in ["derivada", "integral", "función", "límite"]):
            return "Matemáticas"
        elif any(word in tema_lower for word in ["fuerza", "movimiento", "energía"]):
            return "Física"
        elif any(word in tema_lower for word in ["reacción", "elemento", "átomo"]):
            return "Química"
        return "General"
    
    def _estimar_tiempo(self, complejidad):
        return round(complejidad * 1.5, 1)
    
    def _recomendar_metodo(self, tipo_tema, complejidad):
        if tipo_tema == "Ciberseguridad":
            return "Conceptos + Labs prácticos"
        elif tipo_tema == "Matemáticas":
            return "Concepto + Demostración + Problemas"
        else:
            return "Lectura + Ejercicios + Repaso espaciado"


