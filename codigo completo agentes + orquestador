# AGENTE 5: DETECTOR DE BRECHAS
# ============================================================

class Agente5_DetectorBrechas:
    """Identifica conceptos no entendidos completamente."""
    
    def diagnosticar(self, tema, respuesta_del_estudiante):
        palabras_clave = ["porque", "por qué", "explicación", "razón"]
        tiene_comprension = any(palabra in respuesta_del_estudiante.lower() for palabra in palabras_clave)
        
        return {
            "tema": tema,
            "tiene_brecha": not tiene_comprension,
            "nivel_comprension": "profunda" if tiene_comprension else "superficial",
            "recomendacion": "Profundizar en este concepto" if not tiene_comprension else "Concepto bien entendido"
        }


