        print("[7/7] MAPAS MENTALES")
        mapa = self.agente7.generar_mapa(tema)
        print(f"  Mapa con {len(mapa['ramas'])} ramas")
        
        print(f"\n{'='*70}")
        print("PROCESAMIENTO COMPLETADO")
        print(f"{'='*70}")
        
        return {
            "tema": tema,
            "analisis": analisis,
            "anclajes": anclajes,
