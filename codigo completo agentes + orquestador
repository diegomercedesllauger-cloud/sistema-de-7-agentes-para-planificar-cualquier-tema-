class Agente2_GeneradorAnclajes:
    """Crea conexiones entre conceptos nuevos y conocimiento previo."""
    
    def __init__(self):
        self.analogias_base = {
            "RSA": {
                "simple": "Buzón de correos: cualquiera mete cartas, solo el dueño las saca",
                "técnica": "Factorizar números primos grandes es difícil",
                "matemática": "e^d ≡ 1 (mod φ(n))"
            },
            "Derivadas": {
                "simple": "Velocidad instantánea de un auto en este momento",
                "técnica": "Pendiente de una curva en un punto específico",
                "matemática": "lim(h→0) [f(x+h) - f(x)] / h"
            }
        }
    
    def generar_anclajes(self, tema_nuevo, lo_que_ya_sabes):
        if tema_nuevo in self.analogias_base:
            analogias = self.analogias_base[tema_nuevo]
        else:
            analogias = self._generar_dinamico(tema_nuevo, lo_que_ya_sabes)
        
        return {
            "tema_nuevo": tema_nuevo,
            "concepto_conocido": lo_que_ya_sabes,
            "anclaje_nivel_1_simple": analogias.get("simple", ""),
            "anclaje_nivel_2_tecnica": analogias.get("técnica", ""),
            "anclaje_nivel_3_matematica": analogias.get("matemática", ""),
        }
    
    def _generar_dinamico(self, tema_nuevo, lo_que_ya_sabes):
        return {
            "simple": f"{tema_nuevo} funciona como {lo_que_ya_sabes}",
            "técnica": f"Estructura análoga a {lo_que_ya_sabes}",
            "matemática": "Principios de conservación"
        }


