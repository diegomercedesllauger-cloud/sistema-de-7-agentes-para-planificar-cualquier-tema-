# AGENTE 3: PLANIFICADOR DE ESPACIAMIENTO
# ============================================================

class Agente3_PlanificadorEspaciamiento:
    """Crea calendario científico de estudio basado en Spacing Effect."""
    
    def __init__(self):
        self.intervalos_optimos = [1, 3, 7, 14, 30, 60]
    
    def crear_plan(self, tema, fecha_examen, horas_disponibles_por_semana):
        hoy = datetime.now()
        try:
            examen = datetime.strptime(fecha_examen, "%d/%m/%Y")
        except:
            return {"error": "Formato incorrecto. Usa DD/MM/YYYY"}
        
        dias_disponibles = (examen - hoy).days
        
        if dias_disponibles <= 0:
            return {"error": "Fecha de examen debe ser en el futuro"}
        
        horas_totales = (dias_disponibles / 7) * horas_disponibles_por_semana
        sesiones = []
        horas_por_sesion = horas_totales / len(self.intervalos_optimos)
        
        for i, intervalo in enumerate(self.intervalos_optimos):
            fecha_sesion = hoy + timedelta(days=intervalo)
            if fecha_sesion > examen:
                break
            
            sesion = {
                "numero_sesion": i + 1,
                "fecha": fecha_sesion.strftime("%d/%m/%Y"),
                "duracion_minutos": int(horas_por_sesion * 60),
            }
            sesiones.append(sesion)
        
        return {
            "tema": tema,
            "dias_disponibles": dias_disponibles,
            "horas_totales": round(horas_totales, 1),
            "sesiones": sesiones,
            "total_sesiones": len(sesiones),
        }


